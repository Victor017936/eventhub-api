{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "type-check": "vue-tsc --noEmit",
        "lint": "eslint resources/js vite.config.js vitest.config.ts eslint.config.js --max-warnings=0",
        "lint:fix": "eslint resources/js vite.config.js eslint.config.js --fix",
        "test": "vitest run --config vitest.config.ts",
        "test:watch": "vitest --config vitest.config.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.8",
        "@vue/test-utils": "^2.4.11",
        "concurrently": "^9.0.1",
        "eslint": "^10.7.0",
        "eslint-plugin-vue": "^10.10.0",
        "globals": "^17.7.0",
        "jsdom": "^29.1.1",
        "laravel-vite-plugin": "^3.1",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.65.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.10",
        "vue-tsc": "^3.3.7"
    },
    "dependencies": {
        "axios": "^1.18.1",
        "pinia": "^4.0.2",
        "vue": "^3.5.40",
        "vue-router": "^5.2.0"
    }
}
